{
  "name": "club32-frontend",
  "version": "0.0.1",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios --device",
    "ios:clean": "npx expo run:ios --device --no-build-cache",
    "ios:release": "expo run:ios --configuration Release --device",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "deploy:web": "./deploy-web.sh",
    "android": "expo run:android"
  },
  "dependencies": {
    "@expo-google-fonts/lora": "^0.4.2",
    "@expo-google-fonts/outfit": "^0.4.3",
    "@expo/metro-runtime": "~6.1.2",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-font": "~14.0.12",
    "expo-iap": "^4.3.4",
    "expo-linear-gradient": "~15.0.8",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.15.0",
    "lucide-react-native": "^1.17.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.17",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|firebase|@firebase/.*))"
    ],
    "moduleNameMapper": {
      "^../firebase$": "<rootDir>/src/__mocks__/firebase.ts",
      "^../../firebase$": "<rootDir>/src/__mocks__/firebase.ts",
      "^firebase/app$": "<rootDir>/src/__mocks__/firebaseApp.ts",
      "^firebase/auth$": "<rootDir>/src/__mocks__/firebaseAuth.ts"
    }
  }
}
