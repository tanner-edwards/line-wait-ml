{
  "expo": {
    "name": "Club 32",
    "slug": "club32",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tannere.club32",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Club 32 uses your location to find your nearest ride and calculate walk times."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tannere.club32"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "name": "Club 32",
      "shortName": "Club32",
      "themeColor": "#222222",
      "backgroundColor": "#ffffff",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-font",
      "expo-notifications",
      "expo-apple-authentication",
      "@react-native-community/datetimepicker"
    ]
  }
}
